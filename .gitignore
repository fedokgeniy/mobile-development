# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
releaseNote.txt

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# IntelliJ / Android Studio
*.iml
.idea/

# Keystore files (IMPORTANT - never commit these)
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Proguard folder generated by Eclipse
proguard/

# Google Services (e.g. Maps API key, Firebase)
google-services.json
firebase.app.json

# Android Profiling
*.hprof

# Kotlin
.kotlin/

# Navigation (Jetpack)
# (auto-generated SafeArgs or navigation component build artifacts)
